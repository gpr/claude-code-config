        "*.digitalocean.com",
        "*.docker.com",
        "*.dynatrace.com",
        "*.figma.com",
        "*.fly.dev",
        "*.gcp.com",
        "*.github.com",
        "*.gitlabusercontent.com",
        "*.gitlab.com",
        "*.googleapis.com",
        "*.heroku.com",
        "*.ibm.com",
        "*.intercom.com",
        "*.loggly.com",
        "*.microsoft.com",
        "*.mixpanel.com",
        "*.netlify.com",
        "*.newrelic.com",
        "*.npmjs.org",
        "*.oraclecloud.com",
        "*.pagerduty.com",
        "*.papertrailapp.com",
        "*.pingdom.com",
