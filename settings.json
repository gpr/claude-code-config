  "alwaysThinkingEnabled": false,
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "plansDirectory": ".claude/plans",
  "skipDangerousModePermissionPrompt": false,
  "teammateMode": "auto",
  "remoteControlAtStartup": true
}
